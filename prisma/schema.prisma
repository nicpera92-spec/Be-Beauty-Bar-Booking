generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Service {
  id            String     @id @default(cuid())
  technicianId  String
  technician    Technician @relation(fields: [technicianId], references: [id], onDelete: Cascade)
  name          String
  category      String     // nails | lash | permanent-makeup | custom slug
  position      Int        @default(0)
  durationMin   Int
  price         Float      @default(0)
  depositAmount Float
  requiresDeposit Boolean  @default(true) // when false, bookings confirm without a deposit payment
  description   String?    @default("")
  active        Boolean    @default(true)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  addOns        AddOn[]
  bookings      Booking[]
  waitingListEntries WaitingListEntry[]
}

model AddOn {
  id        String   @id @default(cuid())
  serviceId String
  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  name      String
  price     Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Technician {
  id           String    @id @default(cuid())
  name         String
  bio          String?   @default("")
  skillLevel   String?   @default("")
  instagramHandle String?
  role         String    @default("technician") // master | technician
  loginEmail   String?   @unique
  passwordHash String?
  position     Int       @default(0)
  active       Boolean   @default(true)
  categoryOrder String?  // JSON array of category slugs controlling booking-page order
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  services     Service[]
  bookings     Booking[]
  availabilityBlocks AvailabilityBlock[]
  waitingListEntries WaitingListEntry[]
}

model CategoryCapacityRule {
  id            String   @id @default(cuid())
  category      String   @unique // e.g. nails, lash, permanent-makeup
  maxConcurrent Int      @default(1) // max overlapping bookings in this category at once
  updatedAt     DateTime @updatedAt
}

model BusinessSettings {
  id                   String   @id // single row, use "default"
  businessName         String   @default("Be Beauty Bar")
  businessEmail        String?
  adminLoginEmail      String?
  adminPasswordHash    String?
  instagramHandle      String?
  defaultDepositAmount Float?
  defaultPrice         Float?
  openTime             String   @default("09:00")
  closeTime            String   @default("17:00")
  slotInterval         Int      @default(30)
  primaryColor         String?  @default("#1e3a5f")
  secondaryColor       String?  @default("#2c5282")
  stripeSecretKey      String?
  stripeWebhookSecret  String?
  smsNotificationFee   Float?   @default(0.05)
  waitlistEnabled      Boolean  @default(true)
  rebookReminderEnabled   Boolean  @default(false)
  rebookReminderDaysAfter Int      @default(21)
  notificationMessages Json?
  updatedAt            DateTime @updatedAt
}

model WaitingListEntry {
  id                String     @id @default(cuid())
  serviceId         String
  service           Service    @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  technicianId      String
  technician        Technician @relation(fields: [technicianId], references: [id], onDelete: Cascade)
  customerName      String
  customerEmail     String?
  customerPhone     String?
  notifyByEmail     Boolean    @default(true)
  notifyBySMS       Boolean    @default(false)
  preferredDate     String
  preferredDateEnd  String?
  notifyEarliest    Boolean    @default(false)
  status            String     @default("active")
  lastNotifiedAt    DateTime?
  notifiedSlotDate  String?
  notifiedSlotTime  String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  @@index([serviceId, technicianId, preferredDate, status])
  @@index([preferredDate, status])
}

model CustomerNotificationPreference {
  id                   String    @id @default(cuid())
  email                String?   @unique
  phone                String?   @unique
  rebookReminderOptOut Boolean   @default(false)
  rebookOptOutAt       DateTime?
  updatedAt            DateTime  @updatedAt
}

model AvailabilityBlock {
  id           String      @id @default(cuid())
  technicianId String? // null = salon-wide (master); set = that technician's own time off
  technician   Technician? @relation(fields: [technicianId], references: [id], onDelete: Cascade)
  startDate    String
  startTime    String
  endDate      String
  endTime      String
  createdAt    DateTime    @default(now())
}

model BookingAddOn {
  id         String  @id @default(cuid())
  bookingId  String
  booking    Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  addOnId    String
  addOnName  String
  addOnPrice Float
}

model Booking {
  id                            String         @id @default(cuid())
  serviceId                     String
  service                       Service        @relation(fields: [serviceId], references: [id])
  technicianId                  String
  technician                    Technician     @relation(fields: [technicianId], references: [id])
  bookingAddOns                 BookingAddOn[]
  customerName                  String
  customerEmail                 String?
  customerPhone                 String?
  date                          String
  startTime                     String
  endTime                       String
  servicePrice                  Float
  depositAmount                 Float
  balancePaidOnline             Boolean        @default(false)
  status                        String         @default("pending_deposit")
  notes                         String?        @default("")
  notifyByEmail                 Boolean        @default(true)
  notifyBySMS                   Boolean        @default(false)
  stripeDepositPaymentIntentId  String?
  stripeBalancePaymentIntentId  String?
  depositRefundedAt             DateTime?
  balanceRefundedAt             DateTime?
  reminderSentAt                DateTime?
  rebookReminderSentAt          DateTime?
  createdAt                     DateTime       @default(now())
  updatedAt                     DateTime       @updatedAt
}
